NODE_ENV=development
LOG_LEVEL=info
PORT=8080

# Mongo
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=statehash

# Base mainnet (8453) or Base Sepolia (84532)
STATEHASH_CHAIN_ID=8453
STATEHASH_BASE_RPC_URL=https://mainnet.base.org

# System wallet for tx signing when no agent_id is supplied. Treat as the
# "shared / default" signer; per-agent keys are generated and envelope-encrypted
# into Mongo at agent-provisioning time. Keep in Secret Manager/KMS in prod.
STATEHASH_SIGNER_PRIVATE_KEY=0x1111111111111111111111111111111111111111111111111111111111111111

# 32-byte AES-256-GCM master key, base64-encoded. Used to encrypt per-agent
# signing keys at rest. Rotate by generating a new key and re-encrypting rows
# (see docs). Generate a dev-only value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
STATEHASH_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# API keys: comma-separated name:key:namespace triples.
# The `namespace` is the default used when the caller omits it in POST /v1/anchors.
STATEHASH_API_KEYS=smartbettors:shk_dev_change_me:smartbettors
