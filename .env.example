NODE_ENV=development
LOG_LEVEL=info
PORT=8080

# Mongo
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=statehash

# Base mainnet (8453) or Base Sepolia (84532)
STATEHASH_CHAIN_ID=8453
STATEHASH_BASE_RPC_URL=https://mainnet.base.org

# Single system wallet for tx signing. Keep in Secret Manager/KMS in production.
STATEHASH_SIGNER_PRIVATE_KEY=0x1111111111111111111111111111111111111111111111111111111111111111

# API keys: comma-separated name:key:namespace triples.
# The `namespace` is the default used when the caller omits it in POST /v1/anchors.
STATEHASH_API_KEYS=smartbettors:shk_dev_change_me:smartbettors
